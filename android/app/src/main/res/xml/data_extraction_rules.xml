<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+: nie kopiuj danych apki (klucz prywatny E2E, tokeny) do
     backupu w chmurze ani do transferu na nowe urządzenie. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
